# ── High-load recommended config ──────────────────────────────────────
# Uncomment these lines to reduce CPU/RAM usage under heavy traffic:
# RENDER_MODE=manual
# ANALYZE_ON_UPLOAD=false
# MAX_CONCURRENT_OPS=2
# MAX_IMAGE_DIMENSION=5000
# MAX_IMAGE_PIXELS=25000000
# ──────────────────────────────────────────────────────────────────────

# Server (internal)
HOST=0.0.0.0
PORT=8000

# Public port (exposed on host machine)
PUBLIC_PORT=8000

# Upload limits
MAX_UPLOAD_MB=50
MAX_IMAGE_PIXELS=50000000
MAX_IMAGE_DIMENSION=10000
MAX_BASE64_MB=10

# Concurrency (max parallel extract/analyze requests)
MAX_CONCURRENT_OPS=4

# Extraction defaults
DEFAULT_MODE=auto
DEFAULT_THRESHOLD=220
DEFAULT_BLUE_TOLERANCE=80
DEFAULT_SMOOTHING=30
DEFAULT_CONTRAST=50
DEFAULT_FORMAT=png

# Render mode: live (always re-render), manual (button only), auto (switch based on image size)
RENDER_MODE=auto
AUTO_MANUAL_PIXELS=4000000

# Auto-detect presets on upload (calls /analyze in parallel)
ANALYZE_ON_UPLOAD=true

# CORS — Cross-Origin Resource Sharing
# Controls which external domains can call the API from a browser.
# * (wildcard) allows any origin — fine for local dev, NOT for production.
# In production, list only the origins that need access, comma-separated:
#   CORS_ORIGINS=https://myapp.example.com,https://admin.example.com
# If the WebUI and API share the same origin, you can set it to that origin only.
# Reference: https://developer.mozilla.org/en-US/docs/Web/HTTP/CORS
CORS_ORIGINS=*

# Hide configuration warnings in the WebUI (default: false)
HIDE_CONFIG_WARNINGS=false
