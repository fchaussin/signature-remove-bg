# Server (internal)
HOST=0.0.0.0
PORT=8000

# Public port (exposed on host machine)
PUBLIC_PORT=8000

# Upload limits
MAX_UPLOAD_MB=50
MAX_IMAGE_PIXELS=50000000
MAX_IMAGE_DIMENSION=10000

# Extraction defaults
DEFAULT_MODE=auto
DEFAULT_THRESHOLD=220
DEFAULT_BLUE_TOLERANCE=80
DEFAULT_FORMAT=png

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*
